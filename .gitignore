node_modules/
dist/
# agent-runner ships as a JS GitHub Action — its bundled dist/ MUST be committed
# (GitHub runs action.yml `main: dist/index.js` as-is, with no build step).
!agent-runner/dist/
!agent-runner/dist/**
build/
.next/
out/
coverage/
*.tsbuildinfo
.env
.env.local
.DS_Store
.idea/
.turbo/
.pnpm-store/
*.log
.devdigest/cache/
clones/
playwright-report/
test-results/

# emdash worktree config (local)
.emdash.json

# local (untracked) Claude instructions
CLAUDE.local.md

# local scratch / reference material (not for the repo)
.tmp/

# local logs (not for the repo)
.logs/

# pnpm-workspace.yaml is auto-generated and pnpm-version-dependent — keep it local.
# (per-package pnpm-lock.yaml IS committed; the workspace file is not.)
pnpm-workspace.yaml
